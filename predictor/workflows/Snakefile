"""Snakemake DAG for the two-head predictor (Source A + Source B).

    snakemake -c4 -s predictor/workflows/Snakefile      # from repo root
    cd predictor/workflows && snakemake -c4             # from the workflow dir

`all` builds both heads' reports:

* head_a -> openPrimeR in-domain classification + regression (data committed).
* head_b -> ETH PCR-bias cross-source generalization. Requires the ETH repo to
  be fetched first (148 MB, gitignored):
      git clone --depth 1 https://github.com/BorgwardtLab/PCR-bias data/eth_pcr_bias

The working directory is pinned to the repo root so the ``data/...`` paths
resolve regardless of where snakemake is launched. (The earlier simulated
single-head pipeline is retired; its modules remain as a test fixture.)
"""

import os

CONFIG_PATH = os.path.join(workflow.basedir, "configs", "config.yaml")
REPO_ROOT = os.path.abspath(os.path.join(workflow.basedir, "..", ".."))


configfile: CONFIG_PATH
workdir: REPO_ROOT


rule all:
    input:
        "data/reports/head_a.json",
        "data/reports/head_b.json",


rule head_a:
    """openPrimeR: featurize (incl. annealing) -> classification + regression."""
    input:
        matrix=config["head_a"]["matrix"],
        templates=config["head_a"]["templates"],
    output:
        report="data/reports/head_a.json",
        classifier="data/models/head_a_classifier.joblib",
        regressor="data/models/head_a_regressor.joblib",
    shell:
        "python -m predictor.pipeline.head_a"


rule head_b:
    """ETH PCR-bias: internal 5-fold + leave-one-source-out generalization."""
    input:
        data=directory(config["head_b"]["data_dir"]),
    output:
        report="data/reports/head_b.json",
    shell:
        "python -m predictor.pipeline.head_b"
