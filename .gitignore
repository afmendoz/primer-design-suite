# data/ is local-only (fetched sets, generated models/reports) EXCEPT
# data/public/, which holds the committable licensed data (openPrimeR + the
# attributions file). Never commit raw proprietary or wet-lab data.
data/*
!data/.gitkeep
!data/public/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Experiment tracking
.mlflow/
mlruns/

# Snakemake
.snakemake/

# Notebooks
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/

# Test / tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local agent guidance — kept on disk, not published
CLAUDE.md
