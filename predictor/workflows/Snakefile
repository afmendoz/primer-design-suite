"""Snakemake DAG: simulate -> featurize -> train -> evaluate (+ predict).

Runs the same pipeline-stage CLIs used outside Snakemake. Works whether you
launch from the repo root or from ``predictor/workflows/``: the working
directory is pinned to the repo root and the config path is resolved
absolutely from the Snakefile location, so the ``data/...`` paths in the
config always resolve.

    snakemake -c4 -s predictor/workflows/Snakefile      # from repo root
    cd predictor/workflows && snakemake -c4             # from the workflow dir
"""

import os

CONFIG_PATH = os.path.join(workflow.basedir, "configs", "config.yaml")
REPO_ROOT = os.path.abspath(os.path.join(workflow.basedir, "..", ".."))


configfile: CONFIG_PATH
workdir: REPO_ROOT


rule all:
    input:
        config["paths"]["evaluation_report"],
        config["paths"]["predictions"],


rule simulate:
    output:
        dataset=config["paths"]["dataset"],
        provenance=config["paths"]["dataset"].replace(".csv", ".provenance.yaml"),
    params:
        config_path=CONFIG_PATH,
    shell:
        "python -m predictor.pipeline.simulate "
        "--output {output.dataset} --config {params.config_path}"


rule featurize:
    input:
        dataset=config["paths"]["dataset"],
    output:
        features=config["paths"]["feature_table"],
    params:
        config_path=CONFIG_PATH,
    shell:
        "python -m predictor.pipeline.featurize "
        "--dataset {input.dataset} --output {output.features} --config {params.config_path}"


rule train:
    input:
        features=config["paths"]["feature_table"],
    output:
        model=config["paths"]["model_artifact"],
    params:
        model_name=config["model"]["name"],
        config_path=CONFIG_PATH,
    shell:
        "python -m predictor.pipeline.train "
        "--features {input.features} --model {params.model_name} "
        "--output {output.model} --config {params.config_path}"


rule evaluate:
    input:
        model=config["paths"]["model_artifact"],
        features=config["paths"]["feature_table"],
    output:
        report=config["paths"]["evaluation_report"],
    params:
        config_path=CONFIG_PATH,
    shell:
        "python -m predictor.pipeline.evaluate "
        "--model {input.model} --features {input.features} "
        "--output {output.report} --config {params.config_path}"


rule predict:
    input:
        model=config["paths"]["model_artifact"],
        features=config["paths"]["feature_table"],
    output:
        predictions=config["paths"]["predictions"],
    shell:
        "python -m predictor.pipeline.predict "
        "--model {input.model} --features {input.features} --output {output.predictions}"
